# Variables de entorno para el backend

# Puerto del servidor
PORT=5000

# MongoDB URI
# Desarrollo: mongodb://localhost:27017/cultura_local
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/cultura_local
MONGO_URI=mongodb://localhost:27017/cultura_local

# JWT Secret (cambiar en producción)
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cultura_local_secret_key_2026_super_secure

# Entorno
NODE_ENV=development

# CORS Origin (frontend) - separar múltiples URLs con comas
# Desarrollo: http://localhost:5173,http://localhost:5174
# Producción: https://tu-dominio.com,https://www.tu-dominio.com
CORS_ORIGIN=http://localhost:5173

# Directorio de uploads
UPLOAD_DIR=./uploads
