# Variables de entorno para el backend

# Puerto del servidor
PORT=5000

# MongoDB URI
MONGO_URI=mongodb://localhost:27017/cultura_local

# JWT Secret (cambiar en producción)
JWT_SECRET=cultura_local_secret_key_2026_super_secure

# Entorno
NODE_ENV=development

# CORS Origin (frontend)
CORS_ORIGIN=http://localhost:5173

# Directorio de uploads
UPLOAD_DIR=./uploads
